# Azure Entra ID (Azure AD) Configuration
# Copy this file to .env.local and fill in your values

# Application (client) ID from your Entra ID app registration
NEXT_PUBLIC_AZURE_CLIENT_ID=your-client-id-here

# Directory (tenant) ID from your Entra ID
NEXT_PUBLIC_AZURE_TENANT_ID=your-tenant-id-here

# Optional: Override redirect URI (defaults to window.location.origin)
# NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000
